# ============================================================
# AI Gateway — 环境变量配置模板
# ============================================================
# 用法:
#   cp .env.example .env
#   然后编辑 .env,填入你自己的 API Key
#
# 配置优先级(高 → 低):
#   1. 进程真实环境变量(docker-compose environment: 段 / shell export)
#   2. .env 文件(python-dotenv 加载,override=False 不覆盖已存在的环境变量)
#   3. config.yaml 明文值
#   4. 代码内 _DEFAULT_CONFIG 默认值
#
# 说明:
# - 以 AI_GATEWAY_ 开头的变量会由 ConfigManager 自动覆盖 config.yaml 对应路径
#   (例:AI_GATEWAY_SERVER_PORT → config.server.port)
# - config.yaml 中用 ${VAR} 或 ${VAR:-default} 引用本文件变量
#   - ${VAR}        :变量未设时保留字面量(可能导致鉴权失败)
#   - ${VAR:-}      :变量未设时降级为空字符串(优雅降级,gateway 仍能启动)
# - 不填任何 Provider Key 也能启动 gateway(插件 fail-open),
#   但调用 LLM 会鉴权失败 —— 填好 Key 后重启即可。
# ============================================================

# ===== 运行环境 =====
# production :强制 debug_mode=False、log_level≥INFO(部署到共享/生产环境必填)
# development:默认 hot_reload=True、debug_mode=True(本地开发)
AI_GATEWAY_ENV=development

# ===== 基础设施连接(config.yaml 已用 ${VAR:-default} 引用)=====
# Docker Compose 部署时会被 environment: 段覆盖为容器网络地址,无需改动
AI_GATEWAY_REDIS_URL=redis://localhost:6379/0
AI_GATEWAY_QDRANT_URL=http://localhost:6333

# ===== Provider API Keys =====
# 注册地址(开源用户按需申请,填入对应 key):
#   Agnes    :https://agnes-ai.com        (多模态理解 + 图片/视频生成)
#   DeepSeek :https://platform.deepseek.com (纯文本 LLM,注册送额度)
#
# 不用的 provider 可留空(config.yaml 用 ${VAR:-} 降级,该 provider 鉴权会失败但不影响其他功能)
AGNES_API_KEY=
DEEPSEEK_API_KEY=

# ===== 内部网关密钥 =====
# 对话压缩插件(conv_compressor)默认让摘要 LLM 走 gateway 自身(agnes-2.0-flash),
# 避免依赖外部 OPENAI_API_KEY。此处填一个本网关签发的 API Key(在 config.yaml auth.api_keys 中定义)。
# 留空则对话压缩降级为 passthrough(不影响主流程)。
CONV_COMPRESSOR_API_KEY=

# ===== 服务端口(可选,缺省走 config.yaml)=====
# AI_GATEWAY_SERVER_HOST=0.0.0.0
# AI_GATEWAY_SERVER_PORT=8000

# ===== 可观测性(可选)=====
# AI_GATEWAY_OBSERVABILITY_LOG_LEVEL=info
# AI_GATEWAY_OBSERVABILITY_LOG_FORMAT=json

# ===== 配置文件路径(可选,缺省自动搜索 ./config.yaml)=====
# AI_GATEWAY_CONFIG_PATH=./config.yaml
