# AI Gateway 环境变量模板
# 复制为 .env 并填入实际值

# ============================================================
# Gateway 服务配置
# ============================================================
AI_GATEWAY_HOST=0.0.0.0
AI_GATEWAY_PORT=8000
AI_GATEWAY_WORKERS=4
AI_GATEWAY_CONFIG_PATH=./config.yaml
AI_GATEWAY_LOG_LEVEL=info

# ============================================================
# 基础设施连接
# ============================================================
AI_GATEWAY_REDIS_URL=redis://localhost:6379/0
AI_GATEWAY_QDRANT_URL=http://localhost:6333

# ============================================================
# 可观测性
# ============================================================
AI_GATEWAY_PROMETHEUS_ENABLED=true
AI_GATEWAY_OTEL_SAMPLE_RATE=0.1

# ============================================================
# 嵌入模型
# ============================================================
AI_GATEWAY_EMBEDDING_BACKEND=sentence_transformers

# ============================================================
# 预置 API Key（逗号分隔，仅单实例模式）
# ============================================================
AI_GATEWAY_API_KEYS=sk-dev-a1b2c3d4e5f6

# ============================================================
# 下游 LLM 提供商密钥
# ============================================================
OPENAI_API_KEY=sk-proj-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=AIza-xxx
AGNES_API_KEY=your-agnes-api-key
