# ============================================================
# AI Gateway — 环境变量配置模板
# ============================================================
# 复制本文件为 .env 并填入真实值:.env 不入库(gitignore)。
#
# 配置优先级(高 → 低):
#   1. 进程真实环境变量(docker-compose environment: 段 / shell export)
#   2. .env 文件(python-dotenv 加载,override=False 不覆盖已存在的环境变量)
#   3. config.yaml 明文值
#   4. 代码内 _DEFAULT_CONFIG 默认值
#
# 说明:
# - 以 AI_GATEWAY_ 开头的变量会由 ConfigManager 自动覆盖 config.yaml 对应路径
#   (例:AI_GATEWAY_SERVER_PORT → config.server.port)
# - config.yaml 中可用 ${VAR} 或 ${VAR:-default} 引用本文件变量(如 provider api_key)
# ============================================================

# ===== 运行环境 =====
# production: 强制 debug_mode=False、log_level≥INFO
# development: 默认 hot_reload=True、debug_mode=True
AI_GATEWAY_ENV=development

# ===== 基础设施连接(config.yaml 已用 ${VAR:-default} 引用)=====
AI_GATEWAY_REDIS_URL=redis://localhost:6379/0
AI_GATEWAY_QDRANT_URL=http://localhost:6333

# ===== Provider API Keys(敏感)=====
# config.yaml 中 providers.agnes.api_key 引用 ${AGNES_API_KEY}
AGNES_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# config.yaml 中 providers.deepseek.api_key 引用 ${DEEPSEEK_API_KEY}
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 内部网关密钥 =====
# 对话压缩插件(conv_compressor)走 gateway 自身,config.yaml 引用 ${CONV_COMPRESSOR_API_KEY}
CONV_COMPRESSOR_API_KEY=gw-xxxxxxxxxxxxxxxxxxxxx

# ===== 服务端口(可选,缺省走 config.yaml)=====
# AI_GATEWAY_SERVER_HOST=0.0.0.0
# AI_GATEWAY_SERVER_PORT=8000

# ===== 可观测性(可选)=====
# AI_GATEWAY_OBSERVABILITY_LOG_LEVEL=info
# AI_GATEWAY_OBSERVABILITY_LOG_FORMAT=json

# ===== 配置文件路径(可选,缺省自动搜索 ./config.yaml)=====
# AI_GATEWAY_CONFIG_PATH=./config.yaml
