# ============================================================
# .env.docker — 构建加速开关(非敏感,入库共享)
# ============================================================
# Docker 29.1.3 默认走 legacy builder,需显式启用 BuildKit
# BuildKit 提供:并行构建层、更优缓存、增量上下文传输
#
# 用法(二选一):
#   1) set -a && source .env.docker && set +a && docker compose ...
#   2) 直接 sudo DOCKER_BUILDKIT=1 docker compose ...
# ============================================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
